# Optional: project ID (X-Ob-Project-Id header)
# OCEANBASE_PROJECT_ID=li15c8s987d2arse****

# 服务接入点（API 地址，不填则使用默认 api-cloud-cn.oceanbase.com）
# OCEANBASE_ENDPOINT=api-cloud-cn.oceanbase.com
# 采集间隔（秒）：每隔多久请求一次 API
# OCEANBASE_FETCH_INTERVAL=60
# 采集时间范围（秒）：每次请求查询最近多长时间的数据
# OCEANBASE_LOOKBACK_SECONDS=600
