# Required
OCEANBASE_ACCESS_KEY_ID=your_access_key_id
OCEANBASE_ACCESS_KEY_SECRET=your_access_key_secret
OCEANBASE_INSTANCE_ID=ob317v4uif****
OCEANBASE_TENANT_ID=t4louaeei****

# Optional: project ID (X-Ob-Project-Id header)
# OCEANBASE_PROJECT_ID=li15c8s987d2arse****

# Optional: endpoint and fetch timing (see example/ configs)
# OCEANBASE_ENDPOINT=api-cloud-cn.oceanbase.com
# OCEANBASE_FETCH_INTERVAL=60
# OCEANBASE_LOOKBACK_SECONDS=600

# Optional: source filters (used in fluentd_to_loki_all_filters.conf)
# OCEANBASE_DB_NAME=my_database
# OCEANBASE_SEARCH_KEYWORD=SELECT
# OCEANBASE_NODE_IP=10.0.0.1
# OCEANBASE_FILTER_CONDITION=@avgCpuTime > 20
# OCEANBASE_SQL_TEXT_LENGTH=65535
